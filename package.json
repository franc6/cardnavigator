{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "jest",
        "package": "rm -f ../cardnavigator.zip && zip -9rp ../cardnavigator.zip . --exclude \".git/*\" --exclude \"node_modules/*\" --exclude \".phpunit.cache/*\" --exclude \"test/*\" --exclude \"*.zip\" --exclude \".phpunit.*\" --exclude .env --exclude bootstrap/app.php",
        "packagenodb": "rm -f ../cardnavigator.zip && zip -9rp ../cardnavigator.zip . --exclude \".git/*\" --exclude \"node_modules/*\" --exclude \".phpunit.cache/*\" --exclude \"test/*\" --exclude \"*.zip\" --exclude \".phpunit.*\" --exclude .env --exclude bootstrap/app.php --exclude database/database.sqlite",
        "packagebuild": "rm -f build.zip && cd public/build && zip -9rp ../../build.zip * */*"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.5",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": ">=1.11.0 <=1.14.0",
        "babel-jest": "^30.4.1",
        "concurrently": "^9.0.1",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "laravel-vite-plugin": "^3.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^4.3.0",
        "vite": "^8.0.0"
    }
}

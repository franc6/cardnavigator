{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "franc6/cardnavigator",
    "type": "project",
    "description": "Recommends the best credit card to use at nearby merchants using the Google Places API",
    "keywords": ["credit-card", "cashback", "rewards", "google-places", "laravel", "webauthn", "passkey"],
    "homepage": "https://github.com/franc6/cardnavigator",
    "license": "MIT",
    "authors": [
        {
            "name": "Thomas Francis Jr.",
            "homepage": "https://github.com/franc6"
        }
    ],
    "support": {
        "issues": "https://github.com/franc6/cardnavigator/issues",
        "source": "https://github.com/franc6/cardnavigator"
    },
    "require": {
        "php": "^8.4",
        "laragear/webauthn": "^5.0",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpmd/phpmd": "^2.15",
        "phpunit/phpunit": "^12.5.12",
        "squizlabs/php_codesniffer": "^4.0",
        "systemsdk/phpcpd": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "docs": [
            "@php -r \"if (!file_exists('phpDocumentor.phar')) { copy('https://github.com/phpDocumentor/phpDocumentor/releases/download/v3.7.1/phpDocumentor.phar', 'phpDocumentor.phar'); }\"",
            "@php phpDocumentor.phar -c phpdoc.dist.xml"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
